# Copy to keystore.properties (gitignored) or set RELEASE_* env in CI.
# Generate keystore: bash scripts/release/setup-keystore.sh

storeFile=C:/Users/you/.screen-wakelock-detector/release.jks
storePassword=<your-store-password>
keyAlias=release
keyPassword=<your-key-password>

# GitHub Actions secrets (encode keystore once):
#   PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("release.jks"))
#   bash:       base64 -w0 release.jks
# Secrets: RELEASE_STORE_FILE_B64, RELEASE_STORE_PASSWORD, RELEASE_KEY_ALIAS, RELEASE_KEY_PASSWORD
