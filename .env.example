# Environment variables (copy to .env and fill in)
# Never commit .env — it is gitignored.

# Template update checker upstream (optional override)
# TEMPLATE_UPSTREAM=edwardlthompson/agent-project-bootstrap

# Project-specific variables (add below)
# SMOKE_PIN=1234   # optional: unlock device for UI smokes (scripts/smoke/_unlock.sh)
# RELEASE_KEY_PASSWORD=your-keystore-password   # local signed release (scripts/release/ship-local-release.sh)
# API_BASE_URL=http://localhost:3000
# LOG_LEVEL=info
